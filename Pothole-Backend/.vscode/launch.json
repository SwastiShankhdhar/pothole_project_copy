{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Run Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["runserver", "8000"],
            "django": true,
            "autoReload": {
                "enable": true
            },
            "env": {
                "DJANGO_SETTINGS_MODULE": "pothole_backend.settings"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Django: Make Migrations",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["makemigrations"],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "pothole_backend.settings"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Django: Migrate",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["migrate"],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "pothole_backend.settings"
            },
            "console": "integratedTerminal"
        }
    ]
}